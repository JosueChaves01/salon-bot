# Puter.ai API - COMPLETAMENTE GRATUITA (sin API keys requeridas)
# El bot usa Puter.ai que ofrece acceso gratuito a modelos de IA

# Configuracion del salon
SALON_NOMBRE=Salon Bella
SALON_TELEFONO=+50612345678
SALON_HORARIO_INICIO=08:00
SALON_HORARIO_FIN=18:00

# Recordatorios (horas antes de la cita)
HORAS_ANTES_RECORDATORIO=24

# Notificaciones
# Número de WhatsApp de la estilista (Hayssell) incluyendo código de país (ej. 50612345678)
STYLIST_PHONE=

# OpenRouter Configuration
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=YOUR_OPENROUTER_MODEL